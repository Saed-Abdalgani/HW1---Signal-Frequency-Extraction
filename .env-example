# =============================================================================
# Environment Variables — freq_extractor
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# Optional: override the random seed (default: 42 from config/setup.json)
# FREQ_EXTRACTOR_SEED=42

# Optional: force CPU even if CUDA is available (set to "1" to force CPU)
# FREQ_EXTRACTOR_FORCE_CPU=0

# Optional: override the results output directory
# FREQ_EXTRACTOR_RESULTS_DIR=results

# Optional: override the data directory
# FREQ_EXTRACTOR_DATA_DIR=data

# Optional: log level override (DEBUG, INFO, WARNING, ERROR)
# FREQ_EXTRACTOR_LOG_LEVEL=INFO

# =============================================================================
# Future Extension: Remote Storage (not used in current version)
# =============================================================================
# REMOTE_STORAGE_API_KEY=your-api-key-here
# REMOTE_STORAGE_ENDPOINT=https://your-storage-endpoint.example.com
# REMOTE_STORAGE_BUCKET=your-bucket-name
